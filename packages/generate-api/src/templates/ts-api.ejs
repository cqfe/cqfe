<%- jsdoc %>
export function <%= api.name %>(<%= api.params %>): Promise<<%= api.responseType %>> {
  return service({
    url: <%- api.url %>,
    method: '<%= api.method %>',<% if (api.hasQueryParams) { %>
    params: query,<% } %><% if (api.hasBody) { %>
    data: body,<% } %>
    ...options,
  })
}
