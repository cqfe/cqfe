{
  "name": "@cqfe/generate-api",
  "version": "1.0.1",
  "description": "Open API toolkits for JS",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "files": [
    "lib",
    "es",
    "templates",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leoDreamer/cqfe.git"
  },
  "bugs": "https://github.com/leoDreamer/cqfe/issues",
  "author": "leoDreamer <leolichuan@qq.com>",
  "keywords": [
    "generate",
    "swagger",
    "openapi",
    "api"
  ],
  "homepage": "https://cqfe.leoli.site/",
  "license": "MIT",
  "scripts": {
    "test": "jest",
    "lint": "eslint . --ext=.ts,.tsx,.js,.jsx --fix",
    "prebuild": "npx tsc --build --clean",
    "build:lib": "npx tsc --module esnext --outDir lib",
    "build:es": "npx tsc --module esnext --outDir es",
    "postbuild": "cp -r src/templates lib/ && cp -r src/templates es/ && node scripts/fix-imports.cjs",
    "build": "npm run build:lib && npm run build:es"
  },
  "dependencies": {
    "@readme/openapi-parser": "^2.6.0",
    "change-case": "^4.1.2",
    "ejs": "^3.1.10",
    "json-schema-to-jsdoc": "^1.1.1",
    "lodash-es": "^4.17.23",
    "openapi-types": "^12.1.3",
    "openapi-typescript": "^7.10.1"
  },
  "gitHead": "547a82f15b14523514d0aae72374e91c665096b6",
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}
